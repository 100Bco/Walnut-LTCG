# Production domain — used for canonical URLs, sitemap.xml, robots.txt and
# Open Graph tags. Copy this file to .env.local and set your real domain.
NEXT_PUBLIC_SITE_URL=https://www.ltcommercialgroup.com

# Stripe — required for the "Reserve & Pay" room-booking checkout.
# Get these from https://dashboard.stripe.com/apikeys (use test keys locally).
# Without STRIPE_SECRET_KEY the booking form returns a friendly
# "payments not configured" message instead of charging anything.
STRIPE_SECRET_KEY=sk_test_xxx
